/*
 * nextflow.config — profile definitions for the Multiomics Nextflow workflow.
 *
 * Select a profile with:
 *   nextflow run multiomics.nf -profile docker [other args...]
 *   nextflow run multiomics.nf -profile singularity [other args...]
 *   nextflow run multiomics.nf -profile conda [other args...]
 *
 * The ``standard`` profile is used when no -profile flag is supplied.
 */

manifest {
    name            = "multiomics"
    description     = "Multiomics — parallel multi-omics analysis"
    author          = "Multiomics Contributors"
    homePage        = "https://github.com/diladeniz/multiomics"
    version         = "0.1.0"
    nextflowVersion = ">=23.04.0"
    mainScript      = "multiomics.nf"
}

// ---------------------------------------------------------------------------
// Process-level defaults
// ---------------------------------------------------------------------------

process {
    // Default resource labels.  Override per-process with process selectors.
    withLabel: multiomics {
        cpus   = params.threads ?: Runtime.runtime.availableProcessors()
        memory = "8 GB"
        time   = "4 h"
    }
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------

profiles {

    // ------------------------------------------------------------------
    // standard — run natively (no container), multiomics must be on PATH
    // ------------------------------------------------------------------
    standard {
        process.container = ""
        docker.enabled    = false
        singularity.enabled = false
    }

    // ------------------------------------------------------------------
    // docker — use the official Docker image
    // ------------------------------------------------------------------
    docker {
        docker.enabled    = true
        docker.runOptions = "--rm"
        singularity.enabled = false

        process {
            withLabel: multiomics {
                container = "ghcr.io/diladeniz/multiomics:latest"
            }
        }
    }

    // ------------------------------------------------------------------
    // singularity — HPC-friendly, converts the Docker image automatically
    // ------------------------------------------------------------------
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false

        process {
            withLabel: multiomics {
                container = "docker://ghcr.io/diladeniz/multiomics:latest"
            }
        }
    }

    // ------------------------------------------------------------------
    // conda — use a conda environment (requires conda or mamba on PATH)
    // ------------------------------------------------------------------
    conda {
        conda.enabled     = true
        docker.enabled    = false
        singularity.enabled = false

        process {
            withLabel: multiomics {
                // Point at the conda-recipe directory in the repository root.
                conda = "${projectDir}/../conda-recipe/meta.yaml"
            }
        }
    }

    // ------------------------------------------------------------------
    // test — small test run using bundled test data
    // ------------------------------------------------------------------
    test {
        params {
            genomics        = "${projectDir}/../test_data/sample.vcf"
            transcriptomics = "${projectDir}/../test_data/expression.tsv"
            epigenomics     = "${projectDir}/../test_data/methylation.bed"
            output          = "test_results"
            threads         = 2
        }

        process {
            withLabel: multiomics {
                cpus   = 2
                memory = "2 GB"
                time   = "30 m"
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Execution reports (saved alongside the work directory)
// ---------------------------------------------------------------------------

report {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow_timeline.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.output}/nextflow_trace.txt"
}
